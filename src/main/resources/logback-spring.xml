<?xml version="1.0" encoding="UTF-8"?>
<!--
  Structured JSON logging for all environments.

  Spring Boot's built-in ECS encoder (logging.structured.format.console=ecs set in
  application.yml) produces JSON but places MDC keys in an "labels" sub-object.
  This configuration ensures traceId appears as a top-level JSON field so
  CloudWatch Logs Insights can filter on it directly:
    fields traceId | filter traceId = "abc-123"

  The encoder used here is Spring Boot 3.4's native StructuredLogFormatter with
  the ECS format, which maps MDC entries to top-level fields automatically when
  referenced via the <mdcField> element.
-->
<configuration>

  <springProfile name="!test">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>{"@timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","log.level":"%level","traceId":"%X{traceId:-none}","log.logger":"%logger","message":"%message","thread":"%thread"}%n</pattern>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.urlshortener" level="DEBUG"/>
  </springProfile>

  <!-- Plain text in tests for readable output -->
  <springProfile name="test">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <root level="WARN">
      <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.urlshortener" level="INFO"/>
  </springProfile>

</configuration>
